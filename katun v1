        -- TAB AUTO FARM LEVEL
        local FarmTab = Window:NewTab("🌾 Farm Cấp")
        local FarmSection = FarmTab:NewSection("Cày Cấp Tự Động")
        FarmSection:NewToggle("Bật Auto Farm Level", "Tự động nhận quest và đánh quái", function(state)
            _G.AutoFarmLevel = state
        end)

        -- TAB TỘC V4 (TỰ NHÌN & TỰ LẤY GEAR)
        local V4Tab = Window:NewTab("⚙️ Tộc V4 Pro")
        local V4Section = V4Tab:NewSection("Nhiệm vụ Mirage & Gear")
        
        V4Section:NewButton("1. Nói chuyện với MY_GAME43", "Tới Great Tree", function()
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("TalkToNPC", "My_Game43")
        end)

        V4Section:NewToggle("2. Auto Nhìn Trăng", "Tự xoay camera nhìn mặt trăng", function(state)
            _G.AutoLookMoon = state
            task.spawn(function()
                while _G.AutoLookMoon do task.wait()
                    pcall(function()
                        local mirage = game:GetService("Workspace").Map:FindFirstChild("Mirage Island")
                        if mirage then
                            local moon = mirage:FindFirstChild("MoonLocation") or {Position = Vector3.new(0, 1000, 0)}
                            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, moon.Position)
                            game:GetService("VirtualInputManager"):SendKeyEvent(true, "T", false, game)
                        end
                    end)
                end
            end)
        end)

